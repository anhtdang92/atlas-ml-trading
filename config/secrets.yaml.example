# Kraken API Credentials
# Copy this file to secrets.yaml and fill in your actual credentials
# NEVER commit secrets.yaml to git!

kraken:
  api_key: "your_kraken_api_key_here"
  api_secret: "your_kraken_api_secret_here"

# Google Cloud Project
gcp:
  project_id: "your-gcp-project-id"
  bigquery_dataset: "crypto_data"
  storage_bucket: "your-model-storage-bucket"

# Notifications (Optional)
notifications:
  email: "your-email@example.com"
  slack_webhook: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

